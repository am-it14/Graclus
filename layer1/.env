# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub — it contains your private key

# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=#enter your own key

# Windows only: path to Poppler binaries (needed for PDF support)
# Download from: https://github.com/oschwartz10612/poppler-windows/releases
# Extract and set path like below (use forward slashes)
# POPPLER_PATH=C:/poppler-24.08.0/Library/bin

POPPLER_PATH=E:/poppler/poppler-25.12.0/Library/bin
